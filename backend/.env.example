# --- Auth ---
JWT_SECRET=your-secret-key-minimum-32-chars-make-this-random-for-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# --- Admin (separate secret so customer + admin tokens never mix) ---
ADMIN_JWT_SECRET=your-admin-secret-key-MUST-be-different-from-JWT_SECRET
ADMIN_JWT_EXPIRE_HOURS=8
# Seeded admin accounts — change for production
ADMIN_SUPERADMIN_EMAIL=admin@savomart.in
ADMIN_SUPERADMIN_PASSWORD=Admin@123
ADMIN_STORE_MANAGER_EMAIL=manager.indiranagar@savomart.in
ADMIN_STORE_MANAGER_PASSWORD=Store@123
ADMIN_STORE_MANAGER_STORE_ID=indiranagar

# --- Database ---
# When unset, falls back to a local SQLite file at backend/savomart.db
# (zero-setup for dev). On Render, set this to your Neon (or other
# Postgres) connection string for real persistence across deploys.
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# --- OTP ---
OTP_EXPIRE_SECONDS=300

# --- Live Stores API (proxied, never exposed to client) ---
STORES_API_URL=https://internal-service.savomart.in/bridge/api/store/list?is_operational=True
STORES_API_TOKEN=savo-bridge-cron-secret
STORES_CACHE_TTL_SECONDS=300

# --- CORS / Frontend ---
# Comma-separated origins for local dev. Production adds FRONTEND_URL below.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173,http://127.0.0.1:5173
# Deployed frontend URL — set on Render to your Vercel URL (no trailing slash)
FRONTEND_URL=

# --- AI chat (Groq · Llama 3.3 70B) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# --- Runtime ---
ENVIRONMENT=development
